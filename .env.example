# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Restaurant branding (client + server). Defaults to Bella Vista if unset.
NEXT_PUBLIC_RESTAURANT_NAME=Bella Vista

# Restaurant timezone label. PST and PDT are mapped internally to IANA America/Los_Angeles for date/time normalization.
NEXT_PUBLIC_RESTAURANT_TIMEZONE=PST
# Optional server-only override (same semantics as NEXT_PUBLIC; PST/PDT → America/Los_Angeles).
# RESTAURANT_TIMEZONE=PST
